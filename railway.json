{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "env": {
      "MINDOC_ENABLE_EXPORT": "true",
      "DB_ADAPTER": "sqlite3",
      "DB_DATABASE": "/data/mindoc.db",
      "HTTP_PORT": "8080",
      "MINDOC_RUN_MODE": "prod"
    }
  }
}
